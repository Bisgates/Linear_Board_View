# Linear API key — required for /api/refetch and /api/issue/:id
# Get one from https://linear.app/settings/api
LINEAR_API_KEY=

# Tauri updater signing password — required only when running `npm run release`
# (signs the .app.tar.gz bundle).
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=...  # private key at ~/.tauri/board_updater.key, password in password manager
